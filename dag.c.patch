--- Modifications to dag.c for HyMRPL ---

Only two sections need to be changed in the original dag.c.
The rest of the file remains identical.

=== CHANGE 1: in dag_init(), after "dag->mop = mop;" add: ===

    dag->mop = mop;
    dag->node_class = HYMRPL_CLASS_S;  /* default: storing-like */
    dag->parent_last_seen = ev_now(EV_DEFAULT);  /* HyMRPL: avoid false positive on first liveness check */

=== CHANGE 2: in dag_build_dao(), replace the entire switch: ===

Replace:

        switch (dag->mop) {
        case RPL_DIO_STORING_NO_MULTICAST:
                /* fall-through */
        case RPL_DIO_STORING_MULTICAST:
                list_for_each_entry(child, &dag->childs, list) {
                        prefix.prefix = child->addr;
                        prefix.len = 128;

                        append_target(&prefix, sb);
                }
                break;
        default:
                break;
        }

With:

        switch (dag->mop) {
        case RPL_DIO_STORING_NO_MULTICAST:
        case RPL_DIO_STORING_MULTICAST:
                list_for_each_entry(child, &dag->childs, list) {
                        prefix.prefix = child->addr;
                        prefix.len = 128;
                        append_target(&prefix, sb);
                }
                break;
        case RPL_DIO_NONSTORING:
                /*
                 * Non-storing: only send own target (already appended above).
                 * Transit info with parent address is also already appended.
                 * No child aggregation needed — root builds full tree from
                 * individual DAOs.
                 *
                 * NOTE: the original rpld Non-Storing case in dag_build_dao
                 * fell through to default (no explicit case). This explicit
                 * case documents the intended behavior.
                 */
                break;
        case RPL_DIO_HYBRID:
                /*
                 * HyMRPL: Class S nodes include child targets in DAO
                 * (storing-like aggregation). This allows the root to learn
                 * about nodes behind Class S nodes even if intermediate
                 * Class N nodes don't aggregate.
                 *
                 * Class N nodes only send their own target (already appended
                 * above), matching non-storing behavior.
                 */
                if (dag->node_class == HYMRPL_CLASS_S) {
                        list_for_each_entry(child, &dag->childs, list) {
                                prefix.prefix = child->addr;
                                prefix.len = 128;
                                append_target(&prefix, sb);
                        }
                        flog(LOG_INFO, "HYMRPL: class-S DAO includes child targets");
                } else {
                        flog(LOG_INFO, "HYMRPL: class-N DAO (own target only)");
                }
                break;
        default:
                break;
        }

=== No other changes required in dag.c ===

--- Modifications to config.c for HyMRPL ---

Only two sections need to be added to the original config.c.

=== CHANGE 1: in config_load_dags(), after the block that reads mode_of_operation, add: ===

After:
                lua_getfield(L, -1, "mode_of_operation");
                if (lua_isnumber(L, -1)) {
                        mop = lua_tonumber(L, -1);
                } else {
                        mop = RPL_DIO_STORING_NO_MULTICAST;
                }
                lua_pop(L, 1);

Add:
                /* HyMRPL: read node_class from dag config */
                uint8_t dag_node_class = HYMRPL_CLASS_S;
                lua_getfield(L, -1, "node_class");
                if (lua_isstring(L, -1)) {
                        const char *cls = lua_tostring(L, -1);
                        if (cls[0] == 'N' || cls[0] == 'n')
                                dag_node_class = HYMRPL_CLASS_N;
                }
                lua_pop(L, 1);

And after "dag = dag_create(...);" add:
                if (dag) {
                        dag->node_class = dag_node_class;
                }

=== CHANGE 2: in config_load(), after the block that reads mode_of_operation from iface, add: ===

After:
                lua_getfield(L, -1, "mode_of_operation");
                iface->mop = lua_tonumber(L, -1);
                lua_pop(L, 1);

Add:
                /* HyMRPL: read node_class from iface config */
                lua_getfield(L, -1, "node_class");
                if (lua_isstring(L, -1)) {
                        const char *cls = lua_tostring(L, -1);
                        if (cls[0] == 'N' || cls[0] == 'n')
                                iface->node_class = HYMRPL_CLASS_N;
                        else
                                iface->node_class = HYMRPL_CLASS_S;
                } else {
                        iface->node_class = HYMRPL_CLASS_S;
                }
                lua_pop(L, 1);

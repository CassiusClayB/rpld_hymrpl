--- Modificações no config.c para HyMRPL ---

Apenas dois trechos precisam ser adicionados no config.c original.

=== ALTERAÇÃO 1: na função config_load_dags(), após o bloco que lê mode_of_operation, adicionar: ===

Após:
                lua_getfield(L, -1, "mode_of_operation");
                if (lua_isnumber(L, -1)) {
                        mop = lua_tonumber(L, -1);
                } else {
                        mop = RPL_DIO_STORING_NO_MULTICAST;
                }
                lua_pop(L, 1);

Adicionar:
                /* HyMRPL: read node_class from dag config */
                uint8_t dag_node_class = HYMRPL_CLASS_S;
                lua_getfield(L, -1, "node_class");
                if (lua_isstring(L, -1)) {
                        const char *cls = lua_tostring(L, -1);
                        if (cls[0] == 'N' || cls[0] == 'n')
                                dag_node_class = HYMRPL_CLASS_N;
                }
                lua_pop(L, 1);

E após "dag = dag_create(...);" adicionar:
                if (dag) {
                        dag->node_class = dag_node_class;
                }

=== ALTERAÇÃO 2: na função config_load(), após o bloco que lê mode_of_operation da iface, adicionar: ===

Após:
                lua_getfield(L, -1, "mode_of_operation");
                iface->mop = lua_tonumber(L, -1);
                lua_pop(L, 1);

Adicionar:
                /* HyMRPL: read node_class from iface config */
                lua_getfield(L, -1, "node_class");
                if (lua_isstring(L, -1)) {
                        const char *cls = lua_tostring(L, -1);
                        if (cls[0] == 'N' || cls[0] == 'n')
                                iface->node_class = HYMRPL_CLASS_N;
                        else
                                iface->node_class = HYMRPL_CLASS_S;
                } else {
                        iface->node_class = HYMRPL_CLASS_S;
                }
                lua_pop(L, 1);
